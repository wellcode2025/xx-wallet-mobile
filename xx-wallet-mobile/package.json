{
  "name": "xx-wallet-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile-first PWA for the xx network blockchain wallet",
  "scripts": {
    "predev": "node scripts/hash-sleeve-wasm.mjs",
    "dev": "vite",
    "prebuild": "node scripts/hash-sleeve-wasm.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "hash-wasm": "node scripts/hash-sleeve-wasm.mjs"
  },
  "dependencies": {
    "@ledgerhq/hw-transport": "^6.35.4",
    "@ledgerhq/hw-transport-webhid": "^6.35.4",
    "@ledgerhq/hw-transport-webusb": "^6.34.4",
    "@polkadot/api": "^11.0.2",
    "@polkadot/keyring": "^12.6.2",
    "@polkadot/react-identicon": "^3.6.6",
    "@polkadot/util": "^12.6.2",
    "@polkadot/util-crypto": "^12.6.2",
    "@zondax/ledger-substrate": "^0.44.1",
    "bignumber.js": "^9.1.2",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.383.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "scrypt-js": "^3.0.1",
    "tweetnacl": "^1.0.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^1.6.0"
  }
