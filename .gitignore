# Project-root .gitignore for xx-wallet workspace
# (xx-wallet-mobile/ has its own .gitignore for app-specific rules)

# Dependencies (defensive — should be caught by inner .gitignore too)
node_modules/

# Build outputs
dist/
dist-ssr/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS / IDE noise
.DS_Store
Thumbs.db
*Zone.Identifier
*:Zone.Identifier
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Go build artifacts inside sleeve-wasm/. The output artifacts under
# public/sleeve/ (main.wasm + wasm_exec.js) ARE committed so day-to-day
# npm builds don't depend on Go being installed.
xx-wallet-mobile/sleeve-wasm/*.test
xx-wallet-mobile/sleeve-wasm/coverage.out

# Throwaway / scratch
scratch/

# Personal / sensitive — NEVER commit. Local spike scripts + patches contain
# real names, addresses, and throwaway test secrets; they must stay out of the
# public repo. (The spike scripts were purged from history once already — this
# stops any future `git add -A` from re-introducing them.)
xx-wallet-mobile/scripts/spikes/
*.patch
