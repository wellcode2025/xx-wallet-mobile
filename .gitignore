# Project-root .gitignore for xx-wallet workspace
# (xx-wallet-mobile/ has its own .gitignore for app-specific rules)

# Dependencies (defensive — should be caught by inner .gitignore too)
node_modules/

# Build outputs
dist/
dist-ssr/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS / IDE noise
.DS_Store
Thumbs.db
*Zone.Identifier
*:Zone.Identifier
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Go build artifacts inside sleeve-wasm/. The output artifacts under
# public/sleeve/ (main.wasm + wasm_exec.js) ARE committed so day-to-day
# npm builds don't depend on Go being installed.
xx-wallet-mobile/sleeve-wasm/*.test
xx-wallet-mobile/sleeve-wasm/coverage.out

# Throwaway / scratch
scratch/

# Personal / sensitive — NEVER commit. Local spike scripts + patches contain
# real names, addresses, and throwaway test secrets; they must stay out of the
# public repo. (The spike scripts were purged from history once already — this
# stops any future `git add -A` from re-introducing them.)
xx-wallet-mobile/scripts/spikes/
*.patch

# Internal design docs — for internal use only, never the public release.
docs/CMIX_PRIVATE_INDEXER_DESIGN.md

# Audit workstream — security reports, templates, and the user guide drafted
# under it. Belongs to the audit work and must never be published.
.audit/
docs/audit-template/
docs/USER_GUIDE.*

# Internal docs + vendored reference material — never in the public tree.
# Consolidated from .git/info/exclude (2026-07-11, brownfield audit Stage 3)
# so the filter travels with every clone instead of living in local-only
# config. NOTE: CLAUDE.md is deliberately NOT listed — the rewritten
# governing file (facts + rules + tier map) is public by decision.
/docs/HANDOFF.md
/docs/STRATEGY_UPDATE.md
/docs/PROJECT_BRIEF.md
/docs/PHASE_2A_IMPLEMENTATION_PLAN.md
/docs/PHASE_2A_MULTISIG_DESIGN.md
/docs/PHASE_4_GOVERNANCE_IMPLEMENTATION_PLAN.md
/docs/STAKING_INDEXER_FINDINGS.md
/docs/INDEXER_FIX_BRIEF.md
/docs/INDEXER_FIX_PATCH.md
/docs/INDEXER_CRAWLER_RUN.md
/docs/COWORK_QUICKSTART.md
/docs/COWORK_NATIVE_APP_FEEL_PROMPT.md
/docs/WSL_MIGRATION.md
/docs/LEDGER_ACCOUNT_TYPE_SPEC.md
/docs/PROTECTED_ACCOUNT_RECOGNITION_PLAN.md
/docs/AUDIT_SCOPING_BRIEF.md
/docs/test-write.txt
/docs/_to-delete-*
/docs/sleeve-main/
/docs/sleeve-modification-single-seed-main*/
/docs/scripts-main/
/docs/xxfoundation-scripts/
/docs/xxnetwork-js-main/
/docs/_external-reference/
/docs/xx network_media kit/
/docs/xx network_media kit.zip
/xx-wallet-mobile/docs/PHASE_4_GOVERNANCE_HANDOFF.md

# Local workspace folders (never part of the product)
/reference/
/outputs/
/indexer-staking-fix/
